# Copy this to .env and fill in your values

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mybraids
DB_USER=root
DB_PASSWORD=your_password

# JWT secret (generate with: ruby -rsecurerandom -e "puts SecureRandom.hex(64)")
JWT_SECRET=replace_with_64_char_hex

# Cloudinary (free at cloudinary.com)
CLOUDINARY_CLOUD_NAME=sahaKeys
CLOUDINARY_API_KEY=336364856222387
CLOUDINARY_API_SECRET=h6Fl8I8wBmMy6zx7d1WGmnzO__4

# App
PORT=3000
FRONTEND_URL=http://localhost:4200
RACK_ENV=development

# Email (SMTP via Brevo — free at brevo.com, 300 emails/day, no domain verification needed)
# Sign up → Account → SMTP & API → SMTP tab → copy credentials
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_brevo_login_email@example.com
SMTP_PASSWORD=your_brevo_smtp_key
FROM_EMAIL=MyBraids <noreply@mybraids.com>
ADMIN_EMAIL=your_admin@email.com
