# Copy this to .env and fill in your values

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mybraids
DB_USER=root
DB_PASSWORD=your_password

# JWT secret (generate with: ruby -rsecurerandom -e "puts SecureRandom.hex(64)")
JWT_SECRET=replace_with_64_char_hex

# Cloudinary (free at cloudinary.com)
CLOUDINARY_CLOUD_NAME=sahaKeys
CLOUDINARY_API_KEY=336364856222387
CLOUDINARY_API_SECRET=h6Fl8I8wBmMy6zx7d1WGmnzO__4

# App
PORT=3000
FRONTEND_URL=http://localhost:4200
RACK_ENV=development

# Email (Brevo HTTP API — works from any host, no domain verification needed)
# Brevo → Account → SMTP & API → API Keys → Create new key
BREVO_API_KEY=your_brevo_api_key_here
FROM_EMAIL=MyBraids <your_brevo_account_email@gmail.com>
ADMIN_EMAIL=your_admin@email.com
